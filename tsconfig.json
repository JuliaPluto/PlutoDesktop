{
  "compilerOptions": {
    "target": "ES2022",
    "allowJs": true,
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "types": ["bun-types"],
    "paths": {
      "electrobun": ["src/types/electrobun.d.ts"],
      "electrobun/bun": ["src/types/electrobun-bun.d.ts"]
    }
  },
  "include": ["electrobun.config.ts", "src/index.ts", "src/main.ts", "src/enums.ts", "src/globals.ts", "src/logger.ts", "src/paths.ts", "src/pluto.ts", "src/plutoProcess.ts", "src/startup.ts", "src/util.ts", "src/windowsAssociations.ts", "src/windowsDialogs.ts", "src/types/**/*.d.ts"]
}
