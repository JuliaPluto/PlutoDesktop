{
  "name": "pluto-desktop",
  "productName": "Pluto.jl Desktop",
  "version": "1.0.1-build002",
  "description": "Pluto.jl Desktop",
  "main": ".webpack/main",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "set-pluto-version": "node scripts/setPlutoVersion.mjs",
    "start:inspect": "cross-env SKIP_GENERATE_ASSETS=1 electron-forge start -- --remote-debugging-port=9333",
    "start:inspect:assets": "electron-forge start -- --remote-debugging-port=9333",
    "inspect:tabs": "node scripts/listCdpTargets.mjs 9333",
    "inspect:targets": "node scripts/listCdpTargets.mjs 9333",
    "inspect:snapshot": "agent-browser --cdp 9333 snapshot",
    "inspect:snapshot:interactive": "agent-browser --cdp 9333 snapshot -i",
    "inspect:screenshot": "agent-browser --cdp 9333 --screenshot-dir .agent-browser screenshot"
  },
  "keywords": [],
  "author": {
    "name": "Pluto Developers",
    "url": "https://plutojl.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JuliaPluto/PlutoDesktop.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-webpack": "^7.11.2",
    "@electron-forge/publisher-github": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vercel/webpack-asset-relocator-loader": "^1.10.0",
    "agent-browser": "^0.31.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "electron": "43.0.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "extract-zip": "^2.0.1",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "nanospinner": "^1.2.2",
    "node-loader": "^2.1.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.2",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "detect-port": "^2.1.0",
    "electron-log": "^5.4.4",
    "electron-squirrel-startup": "^1.0.1",
    "update-electron-app": "^3.3.0"
  },
  "overrides": {
    "tmp": "^0.2.7",
    "webpack-dev-server": "^5.2.6",
    "tar": "^7.5.16",
    "brace-expansion": "^2.0.2",
    "node-forge": "^1.4.0",
    "@tootallnate/once": "^3.0.1"
  }
}
